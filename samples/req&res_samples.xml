<!--1. Circle Area-->
<!-- Request-->

<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/"
                  xmlns:shp="http://example.com/shapetool">
    <soapenv:Header/>
    <soapenv:Body>
        <shp:circleAreaRequest>
            <shp:radius>5</shp:radius>
        </shp:circleAreaRequest>
    </soapenv:Body>
</soapenv:Envelope>
        <!-- Response-->
<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/"
                  xmlns:shp="http://example.com/shapetool">
<soapenv:Body>
    <shp:circleAreaResponse>
        <shp:area>78.53981633974483</shp:area>
    </shp:circleAreaResponse>
</soapenv:Body>
</soapenv:Envelope>




