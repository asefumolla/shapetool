        <!-- 6. SOAP Fault (Error Example)-->

        <!-- Request (Invalid Input)-->
<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/"
                  xmlns:shp="http://example.com/shapetool">
<soapenv:Header/>
<soapenv:Body>
    <shp:circleAreaRequest>
        <shp:radius>-5</shp:radius>
    </shp:circleAreaRequest>
</soapenv:Body>
</soapenv:Envelope>

        <!-- Response (Fault)-->
<soapenv:Envelope xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/">
<soapenv:Body>
    <soap:Fault>
        <faultcode>soap:Server</faultcode>
        <faultstring>Radius must be greater than 0</faultstring>
    </soap:Fault>
</soapenv:Body>
</soapenv:Envelope>