<?xml version="1.0" encoding="UTF-8"?>

<definitions name="ShapeToolService"
             targetNamespace="http://example.com/shapetool"
             xmlns:tns="http://example.com/shapetool"
             xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/"
             xmlns:xsd="http://www.w3.org/2001/XMLSchema"
             xmlns="http://schemas.xmlsoap.org/wsdl/">

    <!-- ========================= -->
    <!-- TYPES (Correct Import) -->
    <!-- ========================= -->
    <types>
        <xsd:schema>
            <xsd:import
                    namespace="http://example.com/shapetool"
                    schemaLocation="schemas/shapes.xsd"/>
        </xsd:schema>
    </types>

    <!-- ========================= -->
    <!-- MESSAGES -->
    <!-- ========================= -->

    <!-- Circle -->
    <message name="circleAreaRequest">
        <part name="parameters" element="tns:circleAreaRequest"/>
    </message>

    <message name="circleAreaResponse">
        <part name="parameters" element="tns:circleAreaResponse"/>
    </message>

    <!-- Square -->
    <message name="squareAreaRequest">
        <part name="parameters" element="tns:squareAreaRequest"/>
    </message>

    <message name="squareAreaResponse">
        <part name="parameters" element="tns:squareAreaResponse"/>
    </message>

    <!-- Rectangle -->
    <message name="rectangleAreaRequest">
        <part name="parameters" element="tns:rectangleAreaRequest"/>
    </message>

    <message name="rectangleAreaResponse">
        <part name="parameters" element="tns:rectangleAreaResponse"/>
    </message>

    <!-- Parallelogram -->
    <message name="parallelogramAreaRequest">
        <part name="parameters" element="tns:parallelogramAreaRequest"/>
    </message>

    <message name="parallelogramAreaResponse">
        <part name="parameters" element="tns:parallelogramAreaResponse"/>
    </message>

    <!-- Triangle -->
    <message name="triangleAreaRequest">
        <part name="parameters" element="tns:triangleAreaRequest"/>
    </message>

    <message name="triangleAreaResponse">
        <part name="parameters" element="tns:triangleAreaResponse"/>
    </message>

    <!-- ========================= -->
    <!-- PORT TYPE -->
    <!-- ========================= -->
    <portType name="ShapeToolPortType">

        <operation name="circleArea">
            <input message="tns:circleAreaRequest"/>
            <output message="tns:circleAreaResponse"/>
        </operation>

        <operation name="squareArea">
            <input message="tns:squareAreaRequest"/>
            <output message="tns:squareAreaResponse"/>
        </operation>

        <operation name="rectangleArea">
            <input message="tns:rectangleAreaRequest"/>
            <output message="tns:rectangleAreaResponse"/>
        </operation>

        <operation name="parallelogramArea">
            <input message="tns:parallelogramAreaRequest"/>
            <output message="tns:parallelogramAreaResponse"/>
        </operation>

        <operation name="triangleArea">
            <input message="tns:triangleAreaRequest"/>
            <output message="tns:triangleAreaResponse"/>
        </operation>

    </portType>

    <!-- ========================= -->
    <!-- BINDING (IMPORTANT) -->
    <!-- ========================= -->
    <binding name="ShapeToolBinding" type="tns:ShapeToolPortType">

        <soap:binding style="document"
                      transport="http://schemas.xmlsoap.org/soap/http"/>

        <!-- Circle -->
        <operation name="circleArea">
            <soap:operation soapAction="circleArea"/>
            <input><soap:body use="literal"/></input>
            <output><soap:body use="literal"/></output>
        </operation>

        <!-- Square -->
        <operation name="squareArea">
            <soap:operation soapAction="squareArea"/>
            <input><soap:body use="literal"/></input>
            <output><soap:body use="literal"/></output>
        </operation>

        <!-- Rectangle -->
        <operation name="rectangleArea">
            <soap:operation soapAction="rectangleArea"/>
            <input><soap:body use="literal"/></input>
            <output><soap:body use="literal"/></output>
        </operation>

        <!-- Parallelogram -->
        <operation name="parallelogramArea">
            <soap:operation soapAction="parallelogramArea"/>
            <input><soap:body use="literal"/></input>
            <output><soap:body use="literal"/></output>
        </operation>

        <!-- Triangle -->
        <operation name="triangleArea">
            <soap:operation soapAction="triangleArea"/>
            <input><soap:body use="literal"/></input>
            <output><soap:body use="literal"/></output>
        </operation>

    </binding>

    <!-- ========================= -->
    <!-- SERVICE -->
    <!-- ========================= -->
    <service name="ShapeToolService">
        <port name="ShapeToolPort" binding="tns:ShapeToolBinding">
            <soap:address location="http://localhost:8080/ws"/>
        </port>
    </service>

</definitions>